# Entorno de desarrollo local - variables del BACKEND solamente
# Las variables VITE_* van en frontend/.env.local (no las lee Python)

ENV=dev
BACKEND_PORT=8000
FRONTEND_PORT=3000

DB_PATH=data/dev/finanzas_dev.db

ONEDRIVE_PATH=data/dev/onedrive
BACKUP_PATH=data/dev/backups
CONFIG_PATH=config_correos.json

ANTHROPIC_API_KEY=your-key-here
CLAUDE_PROVIDER=mock

MAIL_PROVIDER=mock
OUTLOOK_APP_PASSWORD=
