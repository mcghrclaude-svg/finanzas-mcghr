# Entorno de desarrollo local (sin Docker)
# Copiar como .env y ajustar

# ── Backend ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///C:/Users/ghriz/OneDrive/Finanzas MCGHR/Generales/finanzas.db
ANTHROPIC_API_KEY=your-key-here
ENVIRONMENT=development
DEBUG=true

# ── Frontend ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# Fuente de datos:
#   true  = datos mock (UI sin backend)
#   false = API real (necesita uvicorn corriendo)
VITE_USE_MOCK=true

# Escenario mock (solo aplica cuando VITE_USE_MOCK=true):
#   con_historial = riesgo calculado, línea punteada visible (default)
#   sin_historial = primer mes, sin vel. histórica, badge neutro
VITE_MOCK_SCENARIO=con_historial
